class Solution {
    public boolean isPalindrome(int x) {
          String s=String.valueOf(x);
        if(x<0){
            return false;
        }
       
        
        else{
             int j=s.length();
            
          
            for(int i=0;i<s.length();i++){
                    j--;
                if(s.charAt(i)!=s.charAt(j))
                return false;
            
            }
            return true;
        }
    }
}
