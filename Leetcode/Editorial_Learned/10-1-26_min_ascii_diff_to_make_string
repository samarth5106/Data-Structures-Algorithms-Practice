 minimumDeleteSum(string s1, string s2) {
    int n = s2.length();
    vector<int> dp(n + 1, 0);
    
    for (int j = 1; j <= n; ++j) dp[j] = dp[j-1] + s2[j-1];

    for (char c1 : s1) {
        int prev = dp[0]; 
        dp[0] += c1;
        for (int j = 1; j <= n; ++j) {
            int temp = dp[j];
            if (c1 == s2[j-1]) dp[j] = prev;
            else dp[j] = min(dp[j] + c1, dp[j-1] + s2[j-1]);
            prev = temp;
        }
    }
    return dp[n];
