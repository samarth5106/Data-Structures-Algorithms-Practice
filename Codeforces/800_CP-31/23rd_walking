#include<bits/stdc++.h>
using namespace std;

int main(){
    int t;
    cin >> t;

    while(t--){
        long long a, b, c, d;
        cin >> a >> b >> c >> d;

        if(d < b){
            cout << -1 << endl;
            continue;
        }

        long long diagonal_moves = d - b;
        long long current_x = a + diagonal_moves;

        if(current_x < c){
            cout << -1 << endl;
        }
        else{
            long long left_moves = current_x - c;
            cout << diagonal_moves + left_moves << endl;
        }
    }

    return 0;
}

